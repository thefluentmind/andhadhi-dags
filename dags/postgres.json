{
    "name": "postgres",
    "description": "Fluentmind Postgres Embedding Dag description",
    "operator": "kubernetes",
    "cron": null,
    "params": {},
    "variables": [
        {
            "name": "FLUENTMIND_API_URI",
            "type": "secret"
        },
        {
            "name": "FLUENTMIND_API_KEY",
            "type": "secret"
        }
    ],
    "tags": [
        "thefluentmind",
        "postgres",
        "embeddings"
    ],
    "tasks": [
        {
            "name": "generate-embeddings",
            "depends_on": [],
            "retries": 2,
            "timeout": "30m",
            "container": {
                "image": "node:alpine",
                "env": [
                    {
                        "name": "FLUENTMIND_API_URI",
                        "valueFrom": "FLUENTMIND_API_URI"
                    },
                    {
                        "name": "FLUENTMIND_API_KEY",
                        "valueFrom": "FLUENTMIND_API_KEY"
                    }
                ],
                "command": [
                    "node",
                    "postgres/index.js"
                ]
            }
        }
    ]
}

{
    "name": "Fluentmind Postgres Embedding Dag",
    "description": "Fluentmind Postgres Embedding Dag description",
    "operator": "kubernetes",
    "cron": null,
    "params": {},
    "variables": [
        {
            "name": "POSTGRES_URI",
            "type": "secret"
        }
    ],
    "tags": [
        "thefluentmind",
        "postgres",
        "embeddings"
    ],
    "tasks": [
        {
            "name": "generate-embeddings",
            "depends_on": [],
            "retries": 2,
            "timeout": "30m",
            "container": {
                "image": "node:alpine",
                "env": [
                    {
                        "name": "POSTGRES_URI",
                        "valueFrom": "POSTGRES_URI"
                    }
                ],
                "command": [
                    "node",
                    "postgres/index.js"
                ]
            }
        }
    ]
}